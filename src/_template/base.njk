<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ meta.description }}" />
    <title>{{ meta.title }} | mysite</title>

    {% if noIndex %}
    <meta name="robots" content="noindex" />
    {% endif %} 
     
    {# サイト全体で適用する #}
    <link rel="stylesheet" href="/assets/global/destyle.min.css" />
    <link
      rel="stylesheet"
      href="/assets/global/style.css?{{ lastBuildDate }}"
    />
    <script src="/assets/global/index.js?{{ lastBuildDate }}" defer></script>

    {# ライブラリ　使用するライブラリは各ページで指定する #}
    <script src="/assets/vendors/vue@3.4.20.js" defer></script>
    <script src="/assets/vendors/vuex@4.1.0.js" defer></script>

    {% for vendor in vendors %}
    <script src="/assets/vendors/{{ vendor }}.js" defer></script>
    {% endfor %}
    
    {#ページ固有で適用する　使用するファイルのパスを各ページで指定する#}
    <link rel="stylesheet" href="{{ style }}?{{ lastBuildDate }}" />
    <script src="{{ script }}?{{ lastBuildDate }}" defer></script>
  </head>
  <body>
    <div id="drawer-menu"></div>
    <div id="menu-icon"></div>
    <header id="header"></header>
    <div id="contents">
      <main>
        {{ content | safe }}
      </main>
    </div>
    <footer id="footer"></footer>
  </body>
</html>
